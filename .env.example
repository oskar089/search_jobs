# Database (Neon PostgreSQL)
DATABASE_URL="postgresql+asyncpg://user:password@host:port/database?ssl=require"

# Auth
JWT_SECRET="change-me-to-a-random-secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRES_IN_MINUTES=10080

# App
APP_NAME="Search Jobs"
APP_ENV="development"
DEBUG=true
API_PREFIX="/api"
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Redis (Celery background tasks)
REDIS_URL="redis://localhost:6379/0"

# LLM / OpenAI (for CV matching & cover letters)
LLM_API_KEY=""
LLM_MODEL="gpt-4"
LLM_API_URL="https://api.openai.com/v1/chat/completions"

# Matching
MATCH_THRESHOLD=75

# LinkedIn Import (free Playwright scraper — no API key needed)
LINKEDIN_API_KEY=""              # Leave empty to use free Playwright scraper
LINKEDIN_API_URL="https://api.scrapin.io"
LINKEDIN_EMAIL=""                # Optional: LinkedIn login for Playwright scraper
LINKEDIN_PASSWORD=""             # Optional: LinkedIn login for Playwright scraper

# File Uploads
UPLOAD_DIR="uploads/cv"

# SMTP (email notifications)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@searchjobs.app"
