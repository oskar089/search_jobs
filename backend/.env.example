# =============================================================================
#  Required Config — MUST be set before the application starts
# =============================================================================

# Database connection string (required, no default)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# JWT signing secret — minimum 32 characters, replace with a unique value
# WARNING: "change-me-to-a-random-secret" will be rejected at startup
JWT_SECRET=<min-32-chars>

# Redis connection string (required, no default)
REDIS_URL=redis://:password@redis:6379/0

# =============================================================================
#  Auth
# =============================================================================

JWT_ALGORITHM=HS256
JWT_EXPIRES_IN_MINUTES=15
REFRESH_EXPIRY_DAYS=7

# =============================================================================
#  App
# =============================================================================

APP_NAME=Search Jobs
APP_ENV=development          # development | staging | production
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173

# =============================================================================
#  LLM (for AI cover letter generation)
# =============================================================================

# These are OPTIONAL — LLM features degrade gracefully when not configured
OPENAI_API_KEY=
LLM_API_KEY=
LLM_MODEL=gpt-4
LLM_API_URL=https://api.openai.com/v1/chat/completions

# =============================================================================
#  LinkedIn Import (free Playwright scraper)
# =============================================================================

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# =============================================================================
#  SMTP (for email notifications — OPTIONAL, features degrade gracefully)
# =============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
